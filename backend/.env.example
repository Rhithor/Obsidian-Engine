# LLM Provider: "groq" for production, "ollama" for local dev
# If GROQ_API_KEY is set, the app automatically uses Groq.
LLM_PROVIDER=groq

# Groq (production) — free at console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Ollama (local dev)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ChromaDB Configuration
CHROMA_PATH=./chroma_data

# RAG Configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
N_RESULTS=5

# CORS — set to your Vercel frontend URL in production
# Example: https://obsidian-engine-five.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://obsidian-engine-five.vercel.app
